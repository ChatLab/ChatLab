  "description": "ChatLab MCP Server — shared core for CLI and Desktop, also usable standalone via npx",
  "main": "./dist/index.mjs",
  "bin": {
    "chatlab-mcp": "./dist/bin.mjs"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
